      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "env": {
    "BOT_NAME": "audit-bot",
    "BOT_ROLE": "Compliance review (read-only)",
    "GITHUB_USER": "botfleet-audit",
