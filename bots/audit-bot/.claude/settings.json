{
  "permissions": {
    "allow": [
      "Bash(gh *)",
      "Bash(curl -sf http://172.16.11.10:*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(date *)",
      "Bash(find /home/botuser/workspace *)",
      "Bash(grep *)",
      "Bash(sort *)",
      "Bash(jq *)",
      "Bash(mkdir -p /home/botuser/workspace/*)",
      "Read",
      "Write(/home/botuser/workspace/*)",
      "Edit(/home/botuser/workspace/*)"
