#cloud-config
# Global Admins — SSH keys and emergency access
#
# This file is merged with an application-specific template by the
# proxmox-cloudinit deploy pipeline (two-file merge system).
#
# SSH keys:
#   - admin: Mac Mini key + Proxmox root key + GitHub import for other devices
#   - bot-operator: GitHub import for fleet automation (Jorbot, infra bots)
#   - emergency: break-glass key stored in 1Password "Bot Fleet Vault" vault
#
# Usage:
#   1. Copy to global-admins.yaml
#   2. Verify SSH keys are current (especially break-glass key)
#   3. Place in Proxmox snippets storage (nvmedata:snippets/)
#
# Reference: ecobyte-services/proxmox-cloudinit

users:
  - name: admin
    groups: sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    no_user_group: true
    ssh_authorized_keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIACxzhcIUwA6KcvnAibKgq0rr6Jw/RaG1LYlaaIP9SYw jorgen@remoteproduction.no
      - ssh-rsa  root@proxmox
    ssh_import_id:
      - gh:jorgenscheel

  - name: bot-operator
    groups: sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    ssh_import_id:
      - gh:jorgenscheel
    comment: "Automated fleet management — used by Jorbot and infra bots for SSH access"

  - name: emergency
    groups: sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    ssh_authorized_keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIH1034LyyDPDLac9uHIBoJ/q+cqGzDo/jVN1B3F12bL5 breakglass@botfleet
    comment: "Break-glass emergency access — key stored in 1Password Bot Fleet Vault vault"
