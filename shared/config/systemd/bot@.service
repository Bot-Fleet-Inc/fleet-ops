[Unit]
Description=Bot Fleet - %i
After=network-online.target
Wants=network-online.target
Documentation=https://github.com/Bot-Fleet-Inc/fleet-ops

[Service]
Type=simple
User=bot
Group=bot
WorkingDirectory=/opt/bot/workspace/fleet-ops
EnvironmentFile=/opt/bot/secrets/%i.env
ExecStart=/usr/bin/claude \
    --dangerously-skip-permissions \
    --model sonnet \
    -p "Read the following files in order and then begin your main loop: bots/%i/SOUL.md, bots/%i/IDENTITY.md, bots/%i/CONTEXT.md, bots/%i/AGENTS.md, bots/%i/TOOLS.md, bots/%i/HEARTBEAT.md, bots/%i/MEMORY.md. Then read the latest file in bots/%i/memory/ directory. Begin processing assigned GitHub issues."
Restart=always
RestartSec=60
StartLimitBurst=5
StartLimitIntervalSec=600

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/bot/workspace /opt/bot/secrets /var/log/bot
ProtectHome=true
PrivateTmp=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=bot-%i

[Install]
WantedBy=multi-user.target
